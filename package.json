{
  "name": "@philiprehberger/glob-match",
  "version": "0.1.3",
  "description": "Glob pattern matching — minimatch alternative for runtime use",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "glob",
    "match",
    "pattern",
    "wildcard",
    "filter",
    "minimatch"
  ],
  "author": "Philip Rehberger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-glob-match.git"
  },
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-glob-match/issues"
  },
  "homepage": "https://github.com/philiprehberger/ts-glob-match#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "tsdown": "^0.22.7",
    "typescript": "^7.0.2"
  }
}
